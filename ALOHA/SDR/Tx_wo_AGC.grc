      \ seq_num  (used by Packet Header Generator block)\\n        'user_id'    \u2192\
      \ user_id  (informational)\\n    \", ['initial_delay', 'log_file', 'mean_interval',\
      \ 'packet_size', 'total_packets', 'user_id'])"
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [40, 648.0]
    rotation: 0
    state: enabled
- name: epy_block_2_1_1
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\nimport\
      \ random\nimport time\nimport threading\nimport csv\n\nclass Random_Packet_Generator(gr.basic_block):\n\
      \    \"\"\"\n    Random Packet Generator with embedded userid and sequence number.\n\
      \n    Packet payload layout:\n        [0:2]  \u2013 seq_num  : 2 bytes, big-endian\
      \ uint16\n        [2:4]  \u2013 user_id  : 2 bytes, big-endian uint16  (0\u2013\
      65535)\n        [4:]   \u2013 random data : fills the rest up to packet_size\
      \ bytes\n\n    The PMT metadata dict carries:\n        'packet_num' \u2192 seq_num\
      \  (used by Packet Header Generator block)\n        'user_id'    \u2192 user_id\
      \  (informational)\n    \"\"\"\n\n    def __init__(self,\n                 mean_interval=0.1,\n\
      \                 packet_size=100,\n                 user_id=1,\n          \
      \       log_file=\"transmitted_packets.csv\", \n                 total_packets=10,\n\
      \                 initial_delay=2.0): # 1. ADDED: initial_delay parameter\n\n\
      \        gr.basic_block.__init__(self,\n            name=\"random_packet_generator\"\
      ,\n            in_sig=None,\n            out_sig=None)\n\n        self.message_port_register_out(pmt.intern('pdu_out'))\n\
      \n        # \u2500\u2500 Parameters \u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\n        self.mean_interval = mean_interval\n        self.packet_size\
      \   = packet_size\n        self.user_id       = int(user_id) & 0xFFFF   # clamp\
      \ to uint16\n        self.log_file      = log_file\n        self.total_packets\
      \ = total_packets\n        self.initial_delay = initial_delay           # 2.\
      \ ADDED: store delay attribute\n\n        self.packet_count  = 0\n\n       \
      \ # Header overhead: seq(2) + user_id(2) = 4 bytes\n        if packet_size <=\
      \ 4:\n            raise ValueError(\n                f\"packet_size ({packet_size})\
      \ must be > 4 to fit the header\"\n            )\n\n        # \u2500\u2500 Init\
      \ CSV log \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        with open(self.log_file,\
      \ 'w', newline='') as f:\n            writer = csv.writer(f)\n            writer.writerow([\n\
      \                'packet_id', 'timestamp', 'user_id',\n                'wait_time_s',\
      \ 'data_hex', 'data_bytes'\n            ])\n\n        # \u2500\u2500 Start generator\
      \ thread \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n       \
      \ self.thread = threading.Thread(target=self._generate_packets, daemon=True)\n\
      \        self.thread.start()\n\n    # \u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\n    def _build_payload(self, seq: int)\
      \ -> list:\n        # 1. Define a fixed Access Code (Example: 0xAC or 10101100)\n\
      \        # Use a longer, unique pattern for better correlation (e.g., 32 bits)\n\
      \        #access_code = [0x1A, 0xCF, 0xFC, 0x1A] \n        # access_code = [0xAA,\
      \ 0xAA, 0xAA, 0xAA, 0xE1, 0x5A, 0xE8, 0x93]\n        access_code = [0xE1, 0x5A,\
      \ 0xE8, 0x93]\n\n        filler = [0xE1, 0x5A, 0xE8, 0xAA]  # 4B filler pattern\
      \ to make the preamble more distinct\n\n        # 2. Existing Header [seq_hi,\
      \ seq_lo, uid_hi, uid_lo]\n        header = [\n            (seq >> 8) & 0xFF,\n\
      \            seq & 0xFF,\n            (self.user_id >> 8) & 0xFF,\n        \
      \    self.user_id & 0xFF,\n        ]\n        \n        # 3. Random Data\n \
      \       payload_len = self.packet_size - len(access_code) - len(header)\n  \
      \      random_bytes = [random.randint(0, 255) for _ in range(payload_len)]\n\
      \        \n        # Total Packet: [Preamble] + [Header] + [Payload] + [Filler]\n\
      \        # Note: CRC will be added by the Async CRC32 block after this\n   \
      \     return access_code + header + random_bytes + filler\n\n    # \u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    def\
      \ _generate_packets(self):\n        seq = 0\n        \n        # 3. ADDED: Force\
      \ a hard wait before starting the packet generation loop\n        print(f\"\
      [Random_Packet_Generator TX{self.user_id}] Waiting {self.initial_delay}s for\
      \ hardware warmup...\")\n        time.sleep(self.initial_delay)\n        \n\
      \        # Keep the random stagger so multiple TX blocks don't start at the\
      \ exact same millisecond\n        time.sleep(random.uniform(0, self.mean_interval))\n\
      \        \n        while self.packet_count < self.total_packets:\n         \
      \   wait_time = random.expovariate(1.0 / self.mean_interval)\n            time.sleep(wait_time)\n\
      \n            data = self._build_payload(seq)\n\n            # \u2500\u2500\
      \ Build PMT metadata dict \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            meta = pmt.make_dict()\n\
      \            meta = pmt.dict_add(meta,\n                                pmt.intern('packet_num'),\n\
      \                                pmt.from_long(seq))             # Packet Header\
      \ Generator\n            meta = pmt.dict_add(meta,\n                       \
      \         pmt.intern('user_id'),\n                                pmt.from_long(self.user_id))\
      \    # informational\n\n            # \u2500\u2500 Publish PDU \u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\n            pdu = pmt.cons(meta, pmt.init_u8vector(len(data), data))\n\
      \            self.message_port_pub(pmt.intern('pdu_out'), pdu)\n\n         \
      \   self.packet_count += 1\n            seq = (seq + 1) & 0xFFFF    # 16-bit\
      \ rollover\n\n            # \u2500\u2500 CSV logging \u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \n            timestamp = (time.strftime('%Y-%m-%d %H:%M:%S') +\n          \
      \               f\".{int((time.time() % 1) * 1000):03d}\")\n            data_hex\
      \  = ' '.join(f'{b:02X}' for b in data)\n\n            with open(self.log_file,\
      \ 'a', newline='') as f:\n                writer = csv.writer(f)\n         \
      \       writer.writerow([\n                    self.packet_count,\n        \
      \            timestamp,\n                    self.user_id,\n               \
      \     f\"{wait_time:.4f}\",\n                    data_hex,\n               \
      \     list(data)\n                ])\n\n            print(f\"[PKT {self.packet_count:03d}]\
      \ user_id={self.user_id} \"\n                  f\"seq={seq - 1 & 0xFFFF:#06x}\
      \ \"\n                  f\"after {wait_time:.3f}s | \"\n                  f\"\
      first 4B: {data_hex.split()[:4]}\")"
    affinity: ''
    alias: ''
    comment: ''
    initial_delay: '0'
    log_file: log_file3
    maxoutbuf: '0'
    mean_interval: '0.09'
    minoutbuf: '0'
    packet_size: packet_size
    total_packets: '20'
    user_id: user_id3
  states:
    _io_cache: "('random_packet_generator', 'Random_Packet_Generator', [('mean_interval',\
      \ '0.1'), ('packet_size', '100'), ('user_id', '1'), ('log_file', \"'transmitted_packets.csv'\"\
      ), ('total_packets', '10'), ('initial_delay', '2.0')], [], [('pdu_out', 'message',\
      \ 1)], \"\\n    Random Packet Generator with embedded userid and sequence number.\\\
      n\\n    Packet payload layout:\\n        [0:2]  \u2013 seq_num  : 2 bytes, big-endian\
      \ uint16\\n        [2:4]  \u2013 user_id  : 2 bytes, big-endian uint16  (0\u2013\
      65535)\\n        [4:]   \u2013 random data : fills the rest up to packet_size\
      \ bytes\\n\\n    The PMT metadata dict carries:\\n        'packet_num' \u2192\
      \ seq_num  (used by Packet Header Generator block)\\n        'user_id'    \u2192\
      \ user_id  (informational)\\n    \", ['initial_delay', 'log_file', 'mean_interval',\
      \ 'packet_size', 'total_packets', 'user_id'])"
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [24, 1184.0]
    rotation: 0
    state: enabled
