    _io_cache: '(''EPB: Decode Packet'', ''blk'', [(''log_file'', "''rx_log.csv''"),
      (''preamble_present'', ''False'')], [(''pdu_in'', ''message'', 1)], [(''pdu_out'',
      ''message'', 1)], ''\n    EPB: Decode Packet\n    Updated to handle packets
      with Preambles and CRCs.\n    '', [''log_file''])'
    bus_sink: false
