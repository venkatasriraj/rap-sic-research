- name: epy_block_5
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nimport random\nimport pmt\nfrom gnuradio import\
      \ gr\n\nclass stream_randomizer(gr.sync_block):\n    def __init__(self, sample_rate=768000,\
      \ mean_interval_ms=100.0):\n        gr.sync_block.__init__(\n            self,\n\
      \            name=\"stream_randomizer\",\n            in_sig=[np.complex64],\n\
      \            out_sig=[np.complex64]\n        )\n        self.sample_rate = sample_rate\n\
      \        self.mean_interval_ms = mean_interval_ms          # mean of exponential\
      \ distribution\n\n        self._pad_remaining = 0\n        self._in_packet =\
      \ False\n        self._pkt_remaining = 0\n        self._abs_offset = 0\n\n \
      \       self.set_tag_propagation_policy(gr.TPP_DONT)\n\n    def _draw_gap_samples(self):\n\
      \        \"\"\"Draw gap from Exp(1/mean) and convert to samples.\"\"\"\n   \
      \     gap_ms = random.expovariate(1.0 / self.mean_interval_ms)\n        return\
      \ int(gap_ms * self.sample_rate / 1000.0)\n\n    def work(self, input_items,\
      \ output_items):\n        in0 = input_items[0]\n        out = output_items[0]\n\
      \        nout = len(out)\n        n_written = 0\n        n_consumed = 0\n\n\
      \        tags = self.get_tags_in_window(0, 0, len(in0), pmt.intern(\"packet_len\"\
      ))\n\n        while n_written < nout:\n            if self._in_packet and self._pkt_remaining\
      \ > 0:\n                available = len(in0) - n_consumed\n                chunk\
      \ = min(self._pkt_remaining, nout - n_written, available)\n                if\
      \ chunk == 0:\n                    break\n                out[n_written:n_written\
      \ + chunk] = in0[n_consumed:n_consumed + chunk]\n                self._pkt_remaining\
      \ -= chunk\n                n_written += chunk\n                n_consumed +=\
      \ chunk\n                if self._pkt_remaining == 0:\n                    self._in_packet\
      \ = False\n\n            else:\n                current_abs = self._abs_offset\
      \ + n_consumed\n                remaining_tags = [t for t in tags if t.offset\
      \ >= current_abs]\n                if not remaining_tags:\n                \
      \    n_consumed = len(in0)\n                    break\n                tag =\
      \ remaining_tags[0]\n                pkt_len = pmt.to_long(tag.value)\n    \
      \            self._in_packet = True\n                self._pkt_remaining = pkt_len\n\
      \                skip = int(tag.offset - current_abs)\n                n_consumed\
      \ += skip\n\n        self._abs_offset += n_consumed\n        self.consume(0,\
      \ n_consumed)\n        return n_written"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    mean_interval_ms: '5'
    minoutbuf: '0'
    sample_rate: usrp_rate
  states:
    _io_cache: ('stream_randomizer', 'stream_randomizer', [('sample_rate', '768000'),
      ('mean_interval_ms', '100.0')], [('0', 'complex', 1)], [('0', 'complex', 1)],
      '', ['mean_interval_ms', 'sample_rate'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1344, 1752.0]
    rotation: 0
    state: disabled
- name: epy_block_5_0
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nimport random\nimport pmt\nfrom gnuradio import\
      \ gr\n\nclass stream_randomizer(gr.sync_block):\n    \"\"\"\n    Inserts random\
      \ zero-padding before each packet in the stream domain.\n    Input:  tagged\
      \ stream of complex modulated samples (packet_len tagged)\n    Output: continuous\
      \ stream with random silence gaps between packets\n    \"\"\"\n    def __init__(self,\
      \ sample_rate=768000, min_gap_ms=5, max_gap_ms=50):\n        gr.sync_block.__init__(\n\
      \            self,\n            name=\"stream_randomizer\",\n            in_sig=[np.complex64],\n\
      \            out_sig=[np.complex64]\n        )\n        self.sample_rate = sample_rate\n\
      \        self.min_gap = int(min_gap_ms * sample_rate / 1000)\n        self.max_gap\
      \ = int(max_gap_ms * sample_rate / 1000)\n\n        # Internal state\n     \
      \   self._pad_remaining = 0       # zeros still to emit\n        self._in_packet\
      \ = False       # currently forwarding packet samples?\n        self._pkt_remaining\
      \ = 0       # packet samples left to forward\n\n        self.set_tag_propagation_policy(gr.TPP_DONT)\
      \  # suppress old tags\n\n    def work(self, input_items, output_items):\n \
      \       in0 = input_items[0]\n        out = output_items[0]\n        nout =\
      \ len(out)\n        n_written = 0\n        n_consumed = 0\n\n        tags =\
      \ self.get_tags_in_window(0, 0, len(in0), pmt.intern(\"packet_len\"))\n\n  \
      \      while n_written < nout:\n            if self._pad_remaining > 0:\n  \
      \              # Emit zeros for the random delay\n                chunk = min(self._pad_remaining,\
      \ nout - n_written)\n                out[n_written:n_written + chunk] = 0 +\
      \ 0j\n                self._pad_remaining -= chunk\n                n_written\
      \ += chunk\n\n            elif self._in_packet and self._pkt_remaining > 0:\n\
      \                # Forward actual packet samples\n                available\
      \ = len(in0) - n_consumed\n                chunk = min(self._pkt_remaining,\
      \ nout - n_written, available)\n                if chunk == 0:\n           \
      \         break\n                out[n_written:n_written + chunk] = in0[n_consumed:n_consumed\
      \ + chunk]\n                self._pkt_remaining -= chunk\n                n_written\
      \ += chunk\n                n_consumed += chunk\n                if self._pkt_remaining\
      \ == 0:\n                    self._in_packet = False\n\n            else:\n\
      \                # Look for next packet_len tag\n                remaining_tags\
      \ = [t for t in tags if t.offset >= self._nitems_read(0) + n_consumed]\n   \
      \             if not remaining_tags:\n                    # No more packets\
      \ in this buffer \u2014 consume remainder, emit zeros\n                    n_consumed\
      \ = len(in0)\n                    break\n                tag = remaining_tags[0]\n\
      \                pkt_len = pmt.to_long(tag.value)\n                # Schedule:\
      \ random gap THEN packet\n                gap = random.randint(self.min_gap,\
      \ self.max_gap)\n                self._pad_remaining = gap\n               \
      \ self._in_packet = True\n                self._pkt_remaining = pkt_len\n  \
      \              # Skip input samples up to tag offset\n                skip =\
      \ int(tag.offset - (self._nitems_read(0) + n_consumed))\n                n_consumed\
      \ += skip\n\n        self.consume(0, n_consumed)\n        return n_written\n\
      \n\"\"\"\n## Flowgraph Placement\n\n[Packet Source]\n      \u2193\n[CRC32 Append]\n\
      \      \u2193\n[Protocol Formatter]\n      \u2193\n[PDU to Tagged Stream]\n\
      \      \u2193\n[Chunks to Symbols / Repack]\n      \u2193\n[DBPSK Mod]\n   \
      \   \u2193\n[stream_randomizer EPB]   \u2190 INSERT HERE (after mod, before\
      \ ZMQ)\n      \u2193\n[ZMQ PUSH Sink]\n\n\"\"\"\n\n"
    affinity: ''
    alias: ''
    comment: ''
