      \u2500\u2500\u2500\u2500\u2500\u2500\n    def _build_payload(self, seq: int)\
      \ -> list:\n        access_code = [0xE1, 0x5A, 0xE8, 0x93]                 \
      \   # 4 bytes\n        filler      = [0xDE, 0xAD, 0xBE, 0xEF]              \
      \      # 4 bytes\n\n        header = [\n            (seq >> 8) & 0xFF,\n   \
      \         seq & 0xFF,\n            (self.user_id >> 8) & 0xFF,\n           \
      \ self.user_id & 0xFF,\n        ]                                          \
      \                 # 4 bytes\n\n        # Reserve space for access_code(4) +\
      \ header(4) + CRC(4) + filler(4)\n        payload_len = self.packet_size - len(access_code)\
      \ - len(header) - 4 - len(filler)\n        if payload_len < 0:\n           \
      \ raise ValueError(\n                f\"packet_size ({self.packet_size}) too\
      \ small: need at least \"\n                f\"{len(access_code) + len(header)\
      \ + 4 + len(filler)} bytes \"\n                f\"for fixed fields + CRC\"\n\
      \            )\n        random_bytes = [random.randint(0, 255) for _ in range(payload_len)]\n\
      \n        # CRC32 over header + random_bytes only (access_code and filler excluded)\n\
      \        protected = header + random_bytes\n        crc_val   = binascii.crc32(bytes(protected))\
      \ & 0xFFFFFFFF\n        crc_bytes = list(crc_val.to_bytes(4, byteorder='little'))\n\
      \n        # Final layout: [access_code | header | random_bytes | CRC32 | filler]\n\
      \        return access_code + protected + crc_bytes + filler * 2\n \n    # \u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n \
      \   def _generate_packets(self):\n        seq = 0\n        \n        # 3. ADDED:\
      \ Force a hard wait before starting the packet generation loop\n        print(f\"\
      [Random_Packet_Generator TX{self.user_id}] Waiting {self.initial_delay}s for\
      \ hardware warmup...\")\n        time.sleep(self.initial_delay)\n        \n\
      \        # Keep the random stagger so multiple TX blocks don't start at the\
      \ exact same millisecond\n        time.sleep(random.uniform(0, self.mean_interval))\n\
      \        \n        while self.packet_count < self.total_packets:\n         \
      \   wait_time = random.expovariate(1.0 / self.mean_interval)\n            time.sleep(wait_time)\n\
      \n            data = self._build_payload(seq)\n\n            # \u2500\u2500\
      \ Build PMT metadata dict \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            meta = pmt.make_dict()\n\
      \            meta = pmt.dict_add(meta,\n                                pmt.intern('packet_num'),\n\
      \                                pmt.from_long(seq))             # Packet Header\
      \ Generator\n            meta = pmt.dict_add(meta,\n                       \
      \         pmt.intern('user_id'),\n                                pmt.from_long(self.user_id))\
      \    # informational\n\n            # \u2500\u2500 Publish PDU \u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\n            pdu = pmt.cons(meta, pmt.init_u8vector(len(data), data))\n\
      \            self.message_port_pub(pmt.intern('pdu_out'), pdu)\n\n         \
      \   self.packet_count += 1\n            seq = (seq + 1) & 0xFFFF    # 16-bit\
      \ rollover\n\n            # \u2500\u2500 CSV logging \u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\
      \n            timestamp = (time.strftime('%Y-%m-%d %H:%M:%S') +\n          \
      \               f\".{int((time.time() % 1) * 1000):03d}\")\n            data_hex\
      \  = ' '.join(f'{b:02X}' for b in data)\n\n            with open(self.log_file,\
      \ 'a', newline='') as f:\n                writer = csv.writer(f)\n         \
      \       writer.writerow([\n                    self.packet_count,\n        \
      \            timestamp,\n                    self.user_id,\n               \
      \     f\"{wait_time:.4f}\",\n                    data_hex,\n               \
      \     list(data)\n                ])\n\n            print(f\"[PKT {self.packet_count:03d}]\
      \ user_id={self.user_id} \"\n                  f\"seq={seq - 1 & 0xFFFF:#06x}\
      \ \"\n                  f\"after {wait_time:.3f}s | \"\n                  f\"\
      first 4B: {data_hex.split()[:4]}\")"
    affinity: ''
    alias: ''
    comment: ''
    initial_delay: '0'
    log_file: log_file5
    maxoutbuf: '0'
    mean_interval: '1'
    minoutbuf: '0'
    packet_size: packet_size
    total_packets: '70'
    user_id: user_id5
  states:
    _io_cache: "('random_packet_generator', 'Random_Packet_Generator', [('mean_interval',\
      \ '0.1'), ('packet_size', '100'), ('user_id', '1'), ('log_file', \"'transmitted_packets.csv'\"\
      ), ('total_packets', '10'), ('initial_delay', '2.0')], [], [('pdu_out', 'message',\
      \ 1)], \"\\nRandom Packet Generator with embedded userid and sequence number.\\\
      n\\nPacket payload layout:\\n    [0:2]  \u2013 seq_num  : 2 bytes, big-endian\
      \ uint16\\n    [2:4]  \u2013 user_id  : 2 bytes, big-endian uint16  (0\u2013\
      65535)\\n    [4:]   \u2013 random data : fills the rest up to packet_size bytes\\\
      n\\nThe PMT metadata dict carries:\\n    'packet_num' \u2192 seq_num  (used\
      \ by Packet Header Generator block)\\n    'user_id'    \u2192 user_id  (informational)\\\
      n\", ['initial_delay', 'log_file', 'mean_interval', 'packet_size', 'total_packets',\
      \ 'user_id'])"
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [56, 1776.0]
    rotation: 0
    state: enabled
- name: epy_block_3
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\nimport\
      \ csv\nimport time\nimport binascii\n\nclass access_code_correlator(gr.sync_block):\n\
      \    \"\"\"\n    Bitwise sliding-window access code correlator with CRC32 verification.\n\
      \n    TX packet wire format:\n        [access_code : 4 B]              <- correlated\
      \ against, consumed\n        [seq_num     : 2 B big-endian]\n        [user_id\
      \     : 2 B big-endian]\n        [random data : (packet_size-16) B]\n      \
      \  [CRC32       : 4 B little-endian] <- over AC+seq+uid+random\n        [filler\
      \      : 4 B]              <- flush bytes, discarded\n\n    Parameters\n   \
      \ ----------\n    packet_size : int   Total bytes from Random_Packet_Generator\
      \ (default 56)\n    threshold   : int   Min bit matches out of 32 to accept\
      \ AC (default 28)\n    log_file    : str   CSV output path\n    \"\"\"\n\n \
      \   ACCESS_CODE_BYTES = [0xE1, 0x5A, 0xE8, 0x93]\n    FILLER_LEN        = 4\n\
      \n    def __init__(self, packet_size=56, threshold=28,\n                 log_file=\"\
      rx_decoded_packets.csv\"):\n\n        gr.sync_block.__init__(self,\n       \
      \     name=\"access_code_correlator\",\n            in_sig=[np.uint8],\n   \
      \         out_sig=[np.uint8])\n\n        self.message_port_register_out(pmt.intern('pdu_out'))\n\
      \n        self.packet_size = int(packet_size)\n        self.threshold   = int(threshold)\n\
      \        self.log_file    = log_file\n\n        self.ac_bits = np.array(\n \
      \           [int(b) for byte in self.ACCESS_CODE_BYTES\n                   \
      \  for b in format(byte, '08b')],\n            dtype=np.uint8)\n        self.ac_len\
      \ = len(self.ac_bits)   # 32\n\n        # After AC consumed: seq(2)+uid(2)+random(pkt-16)+CRC(4)+filler(4)\n\
      \        self.post_ac_bits = (packet_size - 4) * 8\n\n        # random payload\
      \ length\n        self.payload_len = packet_size - 16   # pkt - AC - hdr - CRC\
      \ - filler\n\n        self._buf          = np.empty(0, dtype=np.uint8)\n   \
      \     self._state        = 'SEARCH'\n        self._collect_bits = []\n     \
      \   self._pkt_count    = 0\n\n        with open(self.log_file, 'w', newline='')\
      \ as f:\n            csv.writer(f).writerow([\n                'pkt_index',\
      \ 'rx_time', 'user_id', 'seq_num',\n                'crc_ok', 'payload_hex',\
      \ 'payload_len_bytes'\n            ])\n\n    @staticmethod\n    def _bits_to_bytes(bits):\n\
      \        result = []\n        for i in range(len(bits) // 8):\n            byte\
      \ = 0\n            for b in bits[i*8: i*8+8]:\n                byte = (byte\
      \ << 1) | int(b)\n            result.append(byte)\n        return result\n\n\
      \    def _process_packet(self, collect_bits):\n        raw = self._bits_to_bytes(collect_bits)\n\
      \        # raw layout: [seq(2)][uid(2)][random(payload_len)][CRC(4)][filler(4)]\n\
      \n        # Define your expected filler\n        # EXPECTED_FILLER = [0xDE,\
      \ 0xAD, 0xBE, 0xEF]\n        # actual_filler = raw[-4:]\n\n        # # Check\
      \ if the filler matches\n        # if actual_filler != EXPECTED_FILLER:\n  \
      \      #     # This was likely a false trigger in the middle of a packet\n \
      \       #     return\n\n        if len(raw) < 4 + self.payload_len + 4 + self.FILLER_LEN:\n\
      \            print(f\"[AC_CORR] Too short ({len(raw)} B), discarding\")\n  \
      \          return\n\n        seq_num  = (raw[0] << 8) | raw[1]\n        user_id\
      \  = (raw[2] << 8) | raw[3]\n        payload  = raw[4 : 4 + self.payload_len]\n\
      \        crc_rx   = raw[4 + self.payload_len : 4 + self.payload_len + 4]\n \
      \       # filler = raw[-4:]  \u2014 discarded\n\n        # CRC was computed\
      \ over: seq + uid + random\n        body         = raw[:4 + self.payload_len]\n\
      \        crc_expected = binascii.crc32(bytes(body)) & 0xFFFFFFFF\n        #\
      \ crc_actual   = int.from_bytes(crc_rx, byteorder='little')\n        crc_actual\
      \ = int.from_bytes(bytes(crc_rx), byteorder='little')\n        crc_ok      \
      \ = (crc_expected == crc_actual)\n        print(f\"[AC_CORR] CRC check: expected={crc_expected:#010x}\
      \ actual={crc_actual:#010x} {'OK' if crc_ok else 'FAIL'}\") \n\n        self._pkt_count\
      \ += 1\n        status = \"OK\" if crc_ok else \"FAIL\"\n        print(\n  \
      \          f\"[AC_CORR PKT {self._pkt_count:04d}] \"\n            f\"user_id={user_id}\
      \  seq_num={seq_num:#06x}  \"\n            f\"CRC={status}  payload={len(payload)}\
      \ B\"\n        )\n\n        now     = time.time()\n        rx_time = time.strftime('%Y-%m-%d\
      \ %H:%M:%S', time.localtime(now)) \\\n                  + f\".{int((now % 1)*1000):03d}\"\
      \n        pay_hex = ' '.join(f'{b:02X}' for b in payload)\n\n        with open(self.log_file,\
      \ 'a', newline='') as f:\n            csv.writer(f).writerow([\n           \
      \     self._pkt_count, rx_time, user_id, seq_num,\n                crc_ok, pay_hex,\
      \ len(payload)\n            ])\n\n        meta = pmt.make_dict()\n        meta\
      \ = pmt.dict_add(meta, pmt.intern('user_id'), pmt.from_long(user_id))\n    \
      \    meta = pmt.dict_add(meta, pmt.intern('seq_num'),  pmt.from_long(seq_num))\n\
      \        meta = pmt.dict_add(meta, pmt.intern('crc_ok'),   pmt.from_bool(crc_ok))\n\
      \        pdu  = pmt.cons(meta, pmt.init_u8vector(len(raw), raw))\n        self.message_port_pub(pmt.intern('pdu_out'),\
      \ pdu)\n\n    def work(self, input_items, output_items):\n        in0  = input_items[0]\n\
      \        out0 = output_items[0]\n        out0[:] = in0\n\n        self._buf\
      \ = np.concatenate([self._buf, in0])\n\n        while True:\n            if\
      \ self._state == 'SEARCH':\n                if len(self._buf) < self.ac_len:\n\
      \                    break\n\n                n  = len(self._buf) - self.ac_len\
      \ + 1\n                s  = self._buf.strides[0]\n                W  = np.lib.stride_tricks.as_strided(\n\
      \                         self._buf, shape=(n, self.ac_len), strides=(s, s))\n\
      \                corrs = np.sum(W == self.ac_bits, axis=1)\n               \
      \ hits  = np.where(corrs >= self.threshold)[0]\n\n                if len(hits)\
      \ == 0:\n                    self._buf = self._buf[-(self.ac_len - 1):]\n  \
      \                  break\n\n                idx = int(hits[0])\n           \
      \     print(f\"[AC_CORR] AC @ buf[{idx}] corr={int(corrs[idx])}/32\")\n    \
      \            self._buf          = self._buf[idx + self.ac_len:]\n          \
      \      self._state        = 'COLLECT'\n                self._collect_bits =\
      \ []\n\n            elif self._state == 'COLLECT':\n                still_need\
      \ = self.post_ac_bits - len(self._collect_bits)\n\n                if len(self._buf)\
      \ >= still_need:\n                    self._collect_bits.extend(self._buf[:still_need].tolist())\n\
      \                    self._buf  = self._buf[still_need:]\n                 \
      \   self._process_packet(self._collect_bits)\n                    self._state\
      \ = 'SEARCH'\n                else:\n                    self._collect_bits.extend(self._buf.tolist())\n\
      \                    self._buf = np.empty(0, dtype=np.uint8)\n             \
      \       break\n\n        return len(in0)"
    affinity: ''
    alias: ''
    comment: ''
    log_file: rx_log
    maxoutbuf: '0'
    minoutbuf: '0'
    packet_size: packet_size
    threshold: thresh
  states:
    _io_cache: '(''access_code_correlator'', ''access_code_correlator'', [(''packet_size'',
      ''56''), (''threshold'', ''28''), (''log_file'', "''rx_decoded_packets.csv''")],
      [(''0'', ''byte'', 1)], [(''0'', ''byte'', 1), (''pdu_out'', ''message'', 1)],
      ''\nBitwise sliding-window access code correlator with CRC32 verification.\n\nTX
      packet wire format:\n    [access_code : 4 B]              <- correlated against,
      consumed\n    [seq_num     : 2 B big-endian]\n    [user_id     : 2 B big-endian]\n    [random
      data : (packet_size-16) B]\n    [CRC32       : 4 B little-endian] <- over AC+seq+uid+random\n    [filler      :
      4 B]              <- flush bytes, discarded\n\nParameters\n----------\npacket_size
      : int   Total bytes from Random_Packet_Generator (default 56)\nthreshold   :
      int   Min bit matches out of 32 to accept AC (default 28)\nlog_file    : str   CSV
      output path\n'', [''log_file'', ''packet_size'', ''threshold''])'
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [888, 2920.0]
    rotation: 0
    state: enabled
